# App URL (used for PayMongo success/cancel/webhook absolute URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Optional: server-only key for admin/service-role operations (never expose to the client)
# Required for PayMongo webhook handlers that update bookings without a user session
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PayMongo — https://dashboard.paymongo.com → Developers
# Server only — HTTP Basic auth username; password empty
PAYMONGO_SECRET_KEY=sk_test_xxxxxxxx
# Webhook signing secret from the webhook resource (whsk_...)
PAYMONGO_WEBHOOK_SECRET=whsk_xxxxxxxx
# Optional — only if you use client-side PayMongo.js later
# NEXT_PUBLIC_PAYMONGO_PUBLIC_KEY=pk_test_xxxxxxxx
